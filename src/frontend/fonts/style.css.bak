/* ── Variables globales France Travail ── */
:root {
    --ft-blue:    #283276;
    --ft-blue2:   #406BDE;
    --ft-light:   #DBE3FF;
    --ft-red:     #E1000F;
    --ft-cyan:    #008ECF;
    --ft-bg:      #FAFAF7;
    --ft-border:  #B0BFF0;
    --ft-text:    #1D1E3C;
    --ft-muted:   #6b7a9e;
    --ft-primary: #283276;
    --ft-white:   #FFFFFF;
    --ft-success: #1a7a3c;
    --ft-warn:    #e65000;
}

/* ── Polices Marianne (France Travail) ── */
@font-face {
    font-family: "Marianne";
src: url('/frontend/fonts/Marianne-Regular.woff2') format('woff2');
    font-weight: 400;
    font-display: swap;
}
@font-face {
    font-family: "Marianne";
src: url('/frontend/fonts/Marianne-Medium.woff2') format('woff2');
    font-weight: 500;
    font-display: swap;
}
@font-face {
    font-family: "Marianne";
src: url('/frontend/fonts/Marianne-Bold.woff2') format('woff2');
    font-weight: 700;
    font-display: swap;
}

/* ── Reset ── */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html, body {
    background: var(--ft-bg);
    color: var(--ft-text);
    font-family: "Marianne", sans-serif;
    text-align: center;
}

/* ── Layout ── */
.page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 2rem;
    text-align: left;
}

/* ── Bandeau DSI ── */
.bandeau-dsi {
    background: var(--ft-blue);
    color: var(--ft-white);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-align: center;
    padding: 5px 16px;
    width: 100%;
}

/* ── Header ── */
.header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 2px solid #E8ECF5;
    margin-bottom: 1.5rem;
}

.logo-bar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    margin-bottom: 0;
}

.logo-separateur {
    width: 1px;
    height: 28px;
    background: var(--ft-border);
    margin: 0 10px;
}

/* Pastille rouge inspirée du logo */
.logo-dot {
    width: 14px;
    height: 14px;
    background: var(--ft-red);
    border-radius: 50%;
    flex-shrink: 0;
}

.logo-text {
    font-size: 26px;
    font-weight: 700;
    color: var(--ft-blue);
    letter-spacing: 0.01em;
}

.header-user {
    font-size: 13px;
    color: #444;
    font-weight: 500;
}

.header-logout {
    font-size: 13px;
    color: var(--ft-red);
    text-decoration: none;
}
.header-logout:hover {
    text-decoration: underline;
}

/* ── Badge utilisateur connecté ── */
.ip-badge {
    display: inline-block;
    background: var(--ft-light);
    color: var(--ft-blue);
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 99px;
    margin-bottom: 1.5rem;
}

.badge-admin {
    color: var(--ft-red);
    font-size: 12px;
    margin-left: 6px;
}

.badge-tech {
    color: var(--ft-blue);
    font-size: 12px;
    margin-left: 6px;
}

.logout-link {
    color: var(--ft-muted);
    font-size: 13px;
    text-decoration: none;
}
.logout-link:hover {
    text-decoration: underline;
}

/* ── Boutons ── */
.btn, button#btn {
    display: inline-block;
    background: var(--ft-blue);
    color: var(--ft-white);
    border: none;
    border-radius: 6px;
    padding: 0 2rem;
    height: 44px;
    line-height: 44px;
    font-size: 15px;
    font-weight: 500;
    font-family: "Marianne", sans-serif;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
}
button#btn:hover    { background: var(--ft-cyan); }
button#btn.running  { background: var(--ft-red); }
button#btn:disabled { opacity: 0.7; cursor: not-allowed; }

#btn-clear {
    background: none;
    border: none;
    color: #aaa;
    font-size: 16px;
    cursor: pointer;
    padding: 0 8px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
}
#btn-clear:hover { color: var(--ft-red); }

#btn-comment {
    display: inline-block;
    padding: 8px 16px;
    background: var(--ft-blue);
    color: var(--ft-white);
    border: none;
    border-radius: 6px;
    font-family: inherit;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s;
}
#btn-comment:hover    { background: var(--ft-blue2); }
#btn-comment:disabled { background: #b0b8d8; cursor: not-allowed; }

/* ── Cartes speedtest ── */
.results {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 640px;
    margin: 2rem auto 0;
}

.card-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.card {
    background: var(--ft-white);
    border: 0.5px solid var(--ft-border);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.card-label {
    font-size: 11px;
    color: var(--ft-blue2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    font-weight: 500;
}

.card-value {
    font-size: 40px;
    font-weight: 700;
    color: var(--ft-blue);
    line-height: 1;
    margin-bottom: 4px;
}
.card-value.ping { color: var(--ft-red); }

.card-unit {
    font-size: 12px;
    color: var(--ft-blue2);
}

.progress-bar {
    height: 4px;
    background: var(--ft-light);
    border-radius: 2px;
    margin-top: 12px;
    overflow: hidden;
    width: 100%;
}

.progress-fill {
    height: 100%;
    background: var(--ft-blue);
    border-radius: 2px;
    transition: width 0.1s linear;
}
.progress-fill.ping { background: var(--ft-red); }

.card-desc {
    font-size: 11px;
    color: #999;
    margin-top: 8px;
    line-height: 1.4;
    text-align: center;
}

/* ── Badge verdict dans la carte ── */
.card-verdict {
    margin-top: 0.75rem;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.83rem;
    font-weight: 700;
    align-self: center;
    display: inline-block;
}
.card-verdict.confort     { background: #eafaf1; color: var(--ft-success); }
.card-verdict.fonctionnel { background: #fffbe6; color: #7a5c00; }
.card-verdict.insuffisant { background: #fdecea; color: var(--ft-red); }

/* ── Texte explicatif sous la carte (hors carte) ── */
.card-verdict-desc {
    margin-top: 0.5rem;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.80rem;
    font-weight: 400;
    line-height: 1.4;
    text-align: left;
    border-left: 3px solid transparent;
    display: none;
}
.card-verdict-desc.confort,
.card-verdict-desc.fonctionnel,
.card-verdict-desc.insuffisant { display: block; }
.card-verdict-desc.confort     { background: #eafaf1; color: var(--ft-success); border-left-color: var(--ft-success); }
.card-verdict-desc.fonctionnel { background: #fffbe6; color: #7a5c00;           border-left-color: #f0c040; }
.card-verdict-desc.insuffisant { background: #fdecea; color: var(--ft-red);     border-left-color: var(--ft-red); }

/* ── Messages ── */
.error-msg {
    margin-top: 16px;
    color: #c0392b;
    font-size: 13px;
    text-align: center;
}

.msg-success {
    background: #e8f5e9;
    color: var(--ft-success);
    padding: 10px 16px;
    border-radius: 8px;
    margin-bottom: 1rem;
    font-size: 14px;
}

.msg-error {
    background: #fdecea;
    color: var(--ft-red);
    padding: 10px 16px;
    border-radius: 8px;
    margin-bottom: 1rem;
    font-size: 14px;
}

/* ── Tableaux ── */
.results-table,
.comptes-table,
.comm-table {
    width: 100%;
}

.table-scroll,
.results-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}

/* ── Spinner ── */
.spinner {
    width: 16px;
    height: 16px;
    border: 2px solid #E8ECF5;
    border-top-color: var(--ft-blue);
    border-radius: 50%;
    animation: spin .7s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ── Nationale banner (index) ── */
.nationale-banner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: #f0f4ff;
    border: 1px solid #d0d7f0;
    border-radius: 10px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 1rem;
    font-size: 13px;
    flex-wrap: wrap;
}
.nat-label  { font-weight: 700; color: var(--ft-blue); margin-right: 0.5rem; }
.nat-bloc   { display: flex; align-items: center; gap: 0.75rem; color: #444; }
.filtre-bloc { color: var(--ft-success); font-weight: 600; }
.nat-sep    { color: var(--ft-border); font-size: 1.2rem; }

/* ── Footer ── */
.footer {
    margin-top: 3rem;
    padding: 16px 24px;
    border-top: 1px solid #E8ECF5;
    font-size: 11px;
    color: #aaa;
    text-align: center;
    letter-spacing: 0.03em;
}

/* ── Responsive ── */
@media all and (max-width: 480px) {
    .results      { grid-template-columns: 1fr; max-width: 280px; }
    .card-value   { font-size: 32px; }
}
/* ── Toggle mode rapide / précis ── */
.mode-toggle {
    display: flex;
    border: 1px solid var(--ft-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--ft-white);
}

.mode-btn {
    padding: 6px 14px;
    font-size: 12px;
    font-family: "Marianne", sans-serif;
    font-weight: 500;
    border: none;
    background: transparent;
    color: var(--ft-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}

.mode-btn:hover { background: #f0f4ff; color: var(--ft-primary); }

.mode-btn.active {
    background: var(--ft-primary);
    color: #fff;
}

/* ── Navigation principale ── */
.main-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 24px;
    border-bottom: 1px solid #E8ECF5;
    background: var(--ft-white);
    flex-wrap: wrap;
}

.nav-link {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ft-muted);
    text-decoration: none;
    border-bottom: 3px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
}
.nav-link:hover  { color: var(--ft-primary); border-bottom-color: var(--ft-border); }
.nav-link.active { color: var(--ft-primary); border-bottom-color: var(--ft-primary); font-weight: 700; }

.nav-sep {
    color: var(--ft-border);
    font-size: 1.1rem;
    padding: 0 4px;
    user-select: none;
}

/* ── Encart conseil test (index) ── */
.test-conseil {
    background: #f0f4ff;
    border: 1px solid var(--ft-border);
    border-radius: 10px;
    padding: 14px 20px;
    margin: 0 auto 1.5rem;
    max-width: 640px;
    text-align: left;
    font-size: 13px;
    color: var(--ft-muted);
    line-height: 1.6;
}
.test-conseil strong { color: var(--ft-primary); }
.test-conseil .conseil-titre {
    font-weight: 700;
    color: var(--ft-primary);
    margin-bottom: 6px;
    font-size: 13px;
}



/* ── Lien retour unifié ── */
.lien-retour {
    font-size: 13px;
    color: var(--ft-muted);
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
}
.lien-retour:hover { color: var(--ft-primary); text-decoration: underline; }


/* ══════════════════════════════════════════════════════════════════
   CLASSES PARTAGÉES — utilisées sur plusieurs pages
   ══════════════════════════════════════════════════════════════════ */

/* ── Utilitaire ── */
.hidden { display: none !important; }

/* ── Verdicts cellules tableau ── */
.cell-bon     { background: #e6f4ea; color: #1a7a3c; font-weight: 600; font-size: 13px; }
.cell-moyen   { background: #fff4e0; color: #b45300; font-weight: 600; font-size: 13px; }
.cell-mauvais { background: #fdecea; color: #c0392b; font-weight: 600; font-size: 13px; }

/* ── Stats grid ── */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin: 20px 0;
}

/* ── Badges mode test ── */
.badge-mode {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
}
.badge-precis { background: #EEF0FB; color: #283276; border: 1px solid #C8CEED; }
.badge-rapide { background: #FFF0E8; color: #E65100; border: 1px solid #FFCCAA; }

/* ── Filtre mode (logs + statistiques) ── */
.mode-filter-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.5rem 0 1rem;
    flex-wrap: wrap;
}
.mode-filter-btn {
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border: 1px solid #D0D4E8;
    border-radius: 20px;
    background: #fff;
    color: #6b7a99;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
.mode-filter-btn.active,
.mode-filter-btn:hover { background: #283276; color: #fff; border-color: #283276; }

/* ── Pagination enrichie (partagée) ── */
.pagination-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0.75rem 0;
}
.pagination-info    { font-size: 13px; color: #888; white-space: nowrap; }
.pagination-aller   { display: flex; align-items: center; gap: 0.4rem; font-size: 13px; color: #6b7a99; white-space: nowrap; }
.btn-page {
    font-size: 13px;
    font-weight: 600;
    padding: 5px 14px;
    border: 1px solid #D0D4E8;
    border-radius: 6px;
    background: #fff;
    color: #283276;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
}
.btn-page:hover:not(:disabled) { background: #EEF0FB; }
.btn-page:disabled              { opacity: 0.4; cursor: not-allowed; }
.pagination-input {
    width: 52px;
    padding: 4px 6px;
    font-size: 13px;
    border: 1px solid #D0D4E8;
    border-radius: 6px;
    text-align: center;
    color: #283276;
    font-weight: 600;
}
.pagination-input:focus { outline: none; border-color: #406BDE; box-shadow: 0 0 0 2px #406BDE22; }
.pagination-input::-webkit-outer-spin-button,
.pagination-input::-webkit-inner-spin-button { -webkit-appearance: none; }
.pagination-input { -moz-appearance: textfield; }

/* ── Empty state ── */
.empty { text-align: center; padding: 2rem; color: var(--ft-muted); font-size: 14px; }


/* ── Classes utilitaires partagées ── */
.td-loading {
    text-align: center;
    padding: 24px;
    color: var(--ft-muted);
}
.td-error {
    text-align: center;
    padding: 24px;
    color: #c0392b;
}
.spinner--center {
    margin: 0 auto 8px;
}
.compteur-resultats {
    font-size: 13px;
    color: var(--ft-muted);
    margin-bottom: 8px;
}
.td-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
}


/* ── Chart card (partagée toutes pages) ── */
.chart-card {
    background: var(--ft-white);
    border: .5px solid var(--ft-border);
    border-radius: 12px;
    padding: 1.25rem;
}
.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}
.chart-title    { font-size: 13px; font-weight: 700; color: var(--ft-text); }
.chart-subtitle { font-size: 11px; color: var(--ft-muted); margin-top: 2px; }

/* ── Titre de page unifié ── */
.page-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--ft-primary);
    margin: 1.5rem 0;
}

/* ── Bouton sauvegarde principal ── */
.btn-save {
    background: var(--ft-blue);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 9px 22px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background .15s;
}
.btn-save:hover    { background: var(--ft-blue2); }
.btn-save:disabled { opacity: .5; cursor: not-allowed; }

/* ── Bouton filtre/action compact ── */
.btn-filter {
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    padding: .38rem 1rem;
    background: var(--ft-blue);
    color: var(--ft-white);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background .15s;
}
.btn-filter:hover { background: var(--ft-blue2); }

/* ── Bouton reset (effacer filtres) ── */
.btn-reset {
    display: none;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    padding: .38rem .85rem;
    background: var(--ft-white);
    color: var(--ft-muted);
    border: 1px solid var(--ft-border);
    border-radius: 6px;
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
}
.btn-reset.visible  { display: inline-block; }
.btn-reset:hover    { background: #fde8ea; color: var(--ft-red); border-color: #f5aaaf; }

/* ── Boutons scope / périmètre ── */
.scope-btn {
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 14px;
    background: var(--ft-white);
    color: var(--ft-muted);
    border: 1px solid var(--ft-border);
    border-radius: 20px;
    cursor: pointer;
    transition: background .15s, color .15s, border-color .15s;
}
.scope-btn:hover  { border-color: var(--ft-blue); color: var(--ft-blue); }
.scope-btn.active { background: var(--ft-light); color: var(--ft-blue); border-color: var(--ft-blue2); }

/* ── Bouton export (CSV / PDF) ── */
.btn-export {
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    border: none;
    padding: 6px 14px;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: opacity .15s;
}
.btn-export:hover   { opacity: .85; }
.btn-export-pdf     { background: var(--ft-blue); }
.btn-export-csv     { background: var(--ft-success); }
.btn-export--inline { background: var(--ft-blue2); }

/* ══════════════════════════════════════════════════════════════════
   DARK MODE COMPLET — corrige texte blanc sur fond blanc
   ══════════════════════════════════════════════════════════════════ */

:root {
    color-scheme: light dark;
}

@media (prefers-color-scheme: dark) {

    /* ── Variables surchargées ── */
    :root {
        --ft-bg:      #12131f;
        --ft-text:    #e2e4f0;
        --ft-white:   #1e2030;
        --ft-border:  #2e3260;
        --ft-muted:   #8892b8;
        --ft-light:   #1e2a5a;
        --ft-primary: #7b9af7;
    }

    /* ── Body / layout ── */
    html, body    { background: #12131f; color: #e2e4f0; }
    .page         { background: #12131f; }

    /* ── Header & nav ── */
    .header       { background: #1e2030; border-bottom-color: #2e3260; }
    .logo-text    { color: #7b9af7; }
    .header-user  { color: #c0c8e8; }
    .bandeau-dsi  { background: #0e1028; }
    .main-nav     { background: #1e2030; border-bottom-color: #2e3260; }
    .nav-link     { color: #8892b8; }
    .nav-link:hover  { color: #7b9af7; }
    .nav-link.active { color: #7b9af7; border-bottom-color: #7b9af7; }
    .nav-sep      { color: #2e3260; }

    /* ── Cards speedtest ── */
    .card         { background: #1e2030; border-color: #2e3260; }
    .card-label   { color: #8892b8; }
    .card-value   { color: #e2e4f0; }
    .card-unit    { color: #8892b8; }
    .card-desc    { color: #6b7a9e; }
    .progress-bar { background: #2e3260; }

    /* ── Boutons ── */
    .btn, button#btn { background: #283276; color: #e2e4f0; }
    .btn:hover, button#btn:hover { background: #406BDE; }
    .scope-btn    { background: #1e2030; color: #8892b8; border-color: #2e3260; }
    .scope-btn:hover  { background: #242640; color: #7b9af7; border-color: #406BDE; }
    .scope-btn.active { background: #1e2a5a; color: #7b9af7; border-color: #406BDE; }
    .mode-filter-btn  { background: #1e2030; color: #8892b8; border-color: #2e3260; }
    .mode-filter-btn.active, .mode-filter-btn:hover { background: #283276; color: #e2e4f0; border-color: #406BDE; }
    .btn-reset    { background: #1e2030; color: #8892b8; border-color: #2e3260; }
    .btn-reset:hover { background: #2e1520; color: #E1000F; border-color: #E1000F; }
    .btn-filter   { background: #283276; color: #e2e4f0; }
    .btn-filter:hover { background: #406BDE; }
    #btn-clear    { color: #8892b8; }
    #btn-clear:hover { color: #E1000F; }

    /* ── Inputs / selects ── */
    input, select, textarea {
        background: #1e2030 !important;
        color: #e2e4f0 !important;
        border-color: #2e3260 !important;
    }
    input::placeholder { color: #6b7a9e !important; }
    .search-input { background: #242640 !important; color: #e2e4f0 !important; }
    .search-input:focus { background: #1e2030 !important; }
    .filter-select, .filter-input { background: #1e2030 !important; color: #e2e4f0 !important; }

    /* ── Tableaux ── */
table, th               { color: #e2e4f0 !important; }
td:not(.cell-bon):not(.cell-moyen):not(.cell-mauvais) { color: #e2e4f0 !important; background-color: transparent; }
.cell-bon     { background: #0d2818 !important; color: #4caf82 !important; }
.cell-moyen   { background: #2a2000 !important; color: #e0b030 !important; }
.cell-mauvais { background: #2a0808 !important; color: #e57373 !important; }
    thead th                { background: #1a1c30 !important; color: #8892b8 !important; }
    tbody tr:hover td       { background: #242640 !important; }
    .topflop-table thead th { background: #1a1c30 !important; color: #8892b8 !important; border-bottom-color: #2e3260 !important; }
    .topflop-table tbody tr:hover { background: #242640; }
    .tf-nom   { color: #e2e4f0 !important; }
    .tf-val   { color: #7b9af7 !important; }
    .tf-good  { color: #4caf82 !important; }
    .tf-bad   { color: #e57373 !important; }
    .tf-loading { color: #6b7a9e !important; }
    .alert-table th         { background: #1a1c30 !important; color: #7b9af7 !important; border-bottom-color: #2e3260 !important; }
    .alert-table td         { border-bottom-color: #2e3260 !important; color: #e2e4f0 !important; }
    .alert-table tbody tr:hover td { background: #242640 !important; }
    .comparaison-table th   { background: #1a1c30 !important; color: #7b9af7 !important; border-bottom-color: #2e3260 !important; }
    .comparaison-table td   { border-bottom-color: #2e3260 !important; color: #e2e4f0 !important; }
    .comparaison-table tr:hover td { background: #242640 !important; }
    .comparaison-table .comp-label { color: #7b9af7 !important; }
    .comp-ecart-type td     { background: #1a1c30 !important; }
    .comp-sub               { color: #8892b8 !important; }

    /* ── Chart cards / panels ── */
    .chart-card     { background: #1e2030 !important; border-color: #2e3260 !important; }
    .chart-title    { color: #e2e4f0 !important; }
    .chart-subtitle { color: #8892b8 !important; }
    .chart-badge    { background: #1e2a5a !important; color: #7b9af7 !important; border-color: #2e3260 !important; }
    .kpi-card       { background: #1e2030 !important; border-color: #2e3260 !important; }
    .kpi-value      { color: #e2e4f0 !important; }
    .kpi-label, .kpi-unit, .kpi-sub { color: #8892b8 !important; }

    /* ── Onglets ── */
    .tabs           { border-bottom-color: #2e3260; }
    .tab-btn        { color: #8892b8; }
    .tab-btn:hover  { color: #7b9af7; background: #242640; }
    .tab-btn.active { color: #7b9af7; border-bottom-color: #7b9af7; }

    /* ── Bandeaux ── */
    .nationale-banner { background: #1a1e3a; border-color: #2e3260; }
    .nat-label        { color: #7b9af7; }
    .nat-bloc         { color: #c0c8e8; }
    .filter-banner    { background: #1e2a5a; border-color: #406BDE; color: #7b9af7; }
    .filter-banner-tag { background: #283276; color: #e2e4f0; }
    .search-section   { background: #1e2030; border-color: #2e3260; }
    .search-sep       { background: #2e3260; }

    /* ── Badges verdict ── */
    .card-verdict.confort     { background: #0d2818; color: #4caf82; }
    .card-verdict.fonctionnel { background: #2a2000; color: #e0b030; }
    .card-verdict.insuffisant { background: #2a0808; color: #e57373; }
    .card-verdict-desc.confort     { background: #0d2818; color: #4caf82; border-left-color: #4caf82; }
    .card-verdict-desc.fonctionnel { background: #2a2000; color: #e0b030; border-left-color: #e0b030; }
    .card-verdict-desc.insuffisant { background: #2a0808; color: #e57373; border-left-color: #e57373; }
    .sante-badge.confort     { background: #0d2818; color: #4caf82; border-color: #2a5a3a; }
    .sante-badge.fonctionnel { background: #2a2000; color: #e0b030; border-color: #5a4500; }
    .sante-badge.insuffisant { background: #2a0808; color: #e57373; border-color: #5a2020; }
    .badge-crit { background: #2a0808 !important; color: #e57373 !important; border-color: #5a2020 !important; }
    .badge-warn { background: #2a1800 !important; color: #e0943a !important; border-color: #5a3500 !important; }
    .badge-ok   { background: #0d2818 !important; color: #4caf82 !important; border-color: #2a5a3a !important; }
    .badge-precis  { background: #1a1e3a !important; color: #7b9af7 !important; border-color: #2e3260 !important; }
    .badge-rapide  { background: #2a1800 !important; color: #e0943a !important; border-color: #5a3500 !important; }

    /* ── Heatmap ── */
    .hm-site-th { background: #1e2030 !important; color: #8892b8 !important; }
    .hm-th      { color: #8892b8 !important; }
    .hm-site    { background: #1e2030 !important; color: #e2e4f0 !important; }

    /* ── Carte Leaflet ── */
    .leaflet-popup-content-wrapper { background: #1e2030 !important; color: #e2e4f0 !important; }
    .leaflet-popup-tip             { background: #1e2030 !important; }
    .leaflet-popup-content         { color: #e2e4f0 !important; }
    #carte-leaflet                 { border-color: #2e3260 !important; }
    .carte-legende                 { color: #e2e4f0; }

    /* ── Messages / notices ── */
    .msg-success  { background: #0d2818; color: #4caf82; }
    .msg-error    { background: #2a0808; color: #e57373; }
    .error-msg    { color: #e57373; }
    .td-error      { color: #e57373; }
    .ip-badge     { background: #1e2a5a; color: #7b9af7; }
    .test-conseil { background: #1a1e3a; border-color: #2e3260; color: #8892b8; }
    .test-conseil strong { color: #7b9af7; }

    /* ── Login card ── */
    .login-card   { background: #1e2030 !important; border-color: #2e3260 !important; }

    /* ── Footer / divers ── */
    .footer       { border-top-color: #2e3260; color: #6b7a9e; }
    .lien-retour  { color: #8892b8; }
    .lien-retour:hover { color: #7b9af7; }
    .loader       { color: #8892b8; }
    .empty        { color: #8892b8; }
    .spinner      { border-color: #2e3260; border-top-color: #7b9af7; }
    .topflop-grid .chart-card { background: #1e2030 !important; }
    .chart-wrap   { background: transparent; }

    /* ── Classes partagées ── */
    .cell-bon     { background: #0d2818 !important; color: #4caf82 !important; }
    .cell-moyen   { background: #2a2000 !important; color: #e0b030 !important; }
    .cell-mauvais { background: #2a0808 !important; color: #e57373 !important; }
    .mode-filter-btn  { background: #1e2030; color: #8892b8; border-color: #2e3260; }
    .mode-filter-btn.active, .mode-filter-btn:hover { background: #283276; color: #e2e4f0; border-color: #406BDE; }
    .badge-precis  { background: #1a1e3a !important; color: #7b9af7 !important; border-color: #2e3260 !important; }
    .badge-rapide  { background: #2a1800 !important; color: #e0943a !important; border-color: #5a3500 !important; }
    .btn-page      { background: #1e2030 !important; color: #7b9af7 !important; border-color: #2e3260 !important; }
    .btn-page:hover:not(:disabled) { background: #283276 !important; color: #e2e4f0 !important; }
    .pagination-info, .pagination-aller { color: #6b7a9e; }
    .pagination-input { background: #1e2030 !important; color: #7b9af7 !important; border-color: #2e3260 !important; }
    mark, .surlignage { background: #5a4d00 !important; color: #ffe57a !important; }

}

/* ══════════════════════════════════════════════════════════════════
   MODE DALTONIEN
   Palette accessible pour deutéranopie / protanopie (rouge-vert).
   Activé via la classe .daltonien sur <html>.

   Principe : on ne transmet jamais l'info par la couleur seule.
   Chaque verdict utilise aussi un préfixe textuel (✓ / ~ / ✗)
   et un motif visuel (bordure gauche, icône, graisse).

   Palette choisie :
     Confort     → Bleu  #0072B2  (distinguable par tous les types de daltonisme)
     Fonctionnel → Jaune #E69F00  (jaune-orangé, visible deutéranopie + protanopie)
     Insuffisant → Violet #CC79A7 (violet rosé, distinguable du vert et du rouge)
   ══════════════════════════════════════════════════════════════════ */

/* ── Bouton + menu daltonien ── */
.daltonien-wrapper {
    position: relative;
    display: inline-block;
}

.btn-daltonien {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--ft-light);
    border: 1.5px solid var(--ft-border);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    color: var(--ft-primary);
    font-family: "Marianne", sans-serif;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    white-space: nowrap;
}
.btn-daltonien:hover {
    background: #d0daff;
    border-color: var(--ft-blue2);
    box-shadow: 0 2px 6px rgba(40,50,118,0.15);
}

/* Menu déroulant */
.daltonien-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    background: #fff;
    border: 1.5px solid var(--ft-border);
    border-radius: 10px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.12);
    min-width: 240px;
    z-index: 9999;
    overflow: hidden;
    animation: fadeSlideDown 0.15s ease;
}

@keyframes fadeSlideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
}

.daltonien-option {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    font-family: "Marianne", sans-serif;
    background: none;
    border: none;
    border-bottom: 1px solid var(--ft-border);
    cursor: pointer;
    text-align: left;
    color: var(--ft-text);
    transition: background 0.1s;
    line-height: 1.4;
}
.daltonien-option:last-child { border-bottom: none; }
.daltonien-option:hover      { background: var(--ft-light); }
.daltonien-option small      { font-size: 11px; font-weight: 400; color: var(--ft-muted); }
.daltonien-option--active    { background: var(--ft-light); color: var(--ft-primary); }
.daltonien-option--active::after { content: ' ✓'; color: var(--ft-primary); }


/* ══════════════════════════════════════════════════════════════════
   PALETTES PAR TYPE DE DALTONISME
   ══════════════════════════════════════════════════════════════════

   Deutéranopie  (manque cônes verts)  : bleu #0072B2 / orange #E69F00 / violet #CC79A7
   Protanopie    (manque cônes rouges) : bleu #0072B2 / cyan #56B4E9  / orange #D55E00
   Tritanopie    (manque cônes bleus)  : rose #F0E442 / teal #009E73  / violet #CC79A7
   Achromatopsie (pas de couleur)      : gris clair / gris moyen / gris foncé + motifs
   ══════════════════════════════════════════════════════════════════ */

/* ── Deutéranopie ── */
html.daltonien-deuteranopie .cell-bon     { background: #dce9f5 !important; color: #004e8a !important; border-left: 3px solid #0072B2 !important; }
html.daltonien-deuteranopie .cell-moyen   { background: #fef3d0 !important; color: #7a4800 !important; border-left: 3px solid #E69F00 !important; }
html.daltonien-deuteranopie .cell-mauvais { background: #f5e0ed !important; color: #7a1a50 !important; border-left: 3px solid #CC79A7 !important; }
html.daltonien-deuteranopie .cell-bon::before     { content: '✓ '; font-weight: 700; }
html.daltonien-deuteranopie .cell-moyen::before   { content: '~ '; font-weight: 700; }
html.daltonien-deuteranopie .cell-mauvais::before { content: '✗ '; font-weight: 700; }
html.daltonien-deuteranopie .card-verdict.confort,
html.daltonien-deuteranopie .sante-badge.confort     { background: #dce9f5 !important; color: #004e8a !important; border-color: #0072B2 !important; }
html.daltonien-deuteranopie .card-verdict.fonctionnel,
html.daltonien-deuteranopie .sante-badge.fonctionnel { background: #fef3d0 !important; color: #7a4800 !important; border-color: #E69F00 !important; }
html.daltonien-deuteranopie .card-verdict.insuffisant,
html.daltonien-deuteranopie .sante-badge.insuffisant { background: #f5e0ed !important; color: #7a1a50 !important; border-color: #CC79A7 !important; }
html.daltonien-deuteranopie .badge-verdict--confort     { background: #dce9f5 !important; color: #004e8a !important; border-color: #0072B2 !important; }
html.daltonien-deuteranopie .badge-verdict--fonctionnel { background: #fef3d0 !important; color: #7a4800 !important; border-color: #E69F00 !important; }
html.daltonien-deuteranopie .badge-verdict--insuffisant { background: #f5e0ed !important; color: #7a1a50 !important; border-color: #CC79A7 !important; }
html.daltonien-deuteranopie .cellule-ok { background: #dce9f5 !important; color: #004e8a !important; }
html.daltonien-deuteranopie .cellule-ko { background: #f5e0ed !important; color: #7a1a50 !important; }

/* ── Protanopie ── */
html.daltonien-protanopie .cell-bon     { background: #dce9f5 !important; color: #004e8a !important; border-left: 3px solid #0072B2 !important; }
html.daltonien-protanopie .cell-moyen   { background: #d6eef9 !important; color: #1a5a7a !important; border-left: 3px solid #56B4E9 !important; }
html.daltonien-protanopie .cell-mauvais { background: #fce8d8 !important; color: #7a2800 !important; border-left: 3px solid #D55E00 !important; }
html.daltonien-protanopie .cell-bon::before     { content: '✓ '; font-weight: 700; }
html.daltonien-protanopie .cell-moyen::before   { content: '~ '; font-weight: 700; }
html.daltonien-protanopie .cell-mauvais::before { content: '✗ '; font-weight: 700; }
html.daltonien-protanopie .card-verdict.confort,
html.daltonien-protanopie .sante-badge.confort     { background: #dce9f5 !important; color: #004e8a !important; border-color: #0072B2 !important; }
html.daltonien-protanopie .card-verdict.fonctionnel,
html.daltonien-protanopie .sante-badge.fonctionnel { background: #d6eef9 !important; color: #1a5a7a !important; border-color: #56B4E9 !important; }
html.daltonien-protanopie .card-verdict.insuffisant,
html.daltonien-protanopie .sante-badge.insuffisant { background: #fce8d8 !important; color: #7a2800 !important; border-color: #D55E00 !important; }
html.daltonien-protanopie .badge-verdict--confort     { background: #dce9f5 !important; color: #004e8a !important; border-color: #0072B2 !important; }
html.daltonien-protanopie .badge-verdict--fonctionnel { background: #d6eef9 !important; color: #1a5a7a !important; border-color: #56B4E9 !important; }
html.daltonien-protanopie .badge-verdict--insuffisant { background: #fce8d8 !important; color: #7a2800 !important; border-color: #D55E00 !important; }
html.daltonien-protanopie .cellule-ok { background: #dce9f5 !important; color: #004e8a !important; }
html.daltonien-protanopie .cellule-ko { background: #fce8d8 !important; color: #7a2800 !important; }

/* ── Tritanopie ── */
html.daltonien-tritanopie .cell-bon     { background: #d0f4ea !important; color: #005a3a !important; border-left: 3px solid #009E73 !important; }
html.daltonien-tritanopie .cell-moyen   { background: #fefbd0 !important; color: #7a6a00 !important; border-left: 3px solid #F0E442 !important; }
html.daltonien-tritanopie .cell-mauvais { background: #f5e0ed !important; color: #7a1a50 !important; border-left: 3px solid #CC79A7 !important; }
html.daltonien-tritanopie .cell-bon::before     { content: '✓ '; font-weight: 700; }
html.daltonien-tritanopie .cell-moyen::before   { content: '~ '; font-weight: 700; }
html.daltonien-tritanopie .cell-mauvais::before { content: '✗ '; font-weight: 700; }
html.daltonien-tritanopie .card-verdict.confort,
html.daltonien-tritanopie .sante-badge.confort     { background: #d0f4ea !important; color: #005a3a !important; border-color: #009E73 !important; }
html.daltonien-tritanopie .card-verdict.fonctionnel,
html.daltonien-tritanopie .sante-badge.fonctionnel { background: #fefbd0 !important; color: #7a6a00 !important; border-color: #F0E442 !important; }
html.daltonien-tritanopie .card-verdict.insuffisant,
html.daltonien-tritanopie .sante-badge.insuffisant { background: #f5e0ed !important; color: #7a1a50 !important; border-color: #CC79A7 !important; }
html.daltonien-tritanopie .badge-verdict--confort     { background: #d0f4ea !important; color: #005a3a !important; border-color: #009E73 !important; }
html.daltonien-tritanopie .badge-verdict--fonctionnel { background: #fefbd0 !important; color: #7a6a00 !important; border-color: #F0E442 !important; }
html.daltonien-tritanopie .badge-verdict--insuffisant { background: #f5e0ed !important; color: #7a1a50 !important; border-color: #CC79A7 !important; }
html.daltonien-tritanopie .cellule-ok { background: #d0f4ea !important; color: #005a3a !important; }
html.daltonien-tritanopie .cellule-ko { background: #f5e0ed !important; color: #7a1a50 !important; }

/* ── Achromatopsie (niveaux de gris + motifs distinctifs) ── */
html.daltonien-achromatopsie .cell-bon {
    background: #e8e8e8 !important; color: #1a1a1a !important;
    border-left: 4px solid #444 !important;
    background-image: none !important;
}
html.daltonien-achromatopsie .cell-moyen {
    background: #c0c0c0 !important; color: #1a1a1a !important;
    border-left: 4px dashed #444 !important;
}
html.daltonien-achromatopsie .cell-mauvais {
    background: #888 !important; color: #fff !important;
    border-left: 4px solid #000 !important;
}
html.daltonien-achromatopsie .cell-bon::before     { content: '✓ '; font-weight: 700; }
html.daltonien-achromatopsie .cell-moyen::before   { content: '~ '; font-weight: 700; }
html.daltonien-achromatopsie .cell-mauvais::before { content: '✗ '; font-weight: 700; }
html.daltonien-achromatopsie .card-verdict.confort,
html.daltonien-achromatopsie .sante-badge.confort     { background: #e8e8e8 !important; color: #1a1a1a !important; border-color: #444 !important; }
html.daltonien-achromatopsie .card-verdict.fonctionnel,
html.daltonien-achromatopsie .sante-badge.fonctionnel { background: #c0c0c0 !important; color: #1a1a1a !important; border-color: #666 !important; }
html.daltonien-achromatopsie .card-verdict.insuffisant,
html.daltonien-achromatopsie .sante-badge.insuffisant { background: #888 !important; color: #fff !important; border-color: #000 !important; }
html.daltonien-achromatopsie .badge-verdict--confort     { background: #e8e8e8 !important; color: #1a1a1a !important; border-color: #444 !important; }
html.daltonien-achromatopsie .badge-verdict--fonctionnel { background: #c0c0c0 !important; color: #1a1a1a !important; border-color: #666 !important; }
html.daltonien-achromatopsie .badge-verdict--insuffisant { background: #888 !important; color: #fff !important; border-color: #000 !important; }
html.daltonien-achromatopsie .cellule-ok { background: #e8e8e8 !important; color: #1a1a1a !important; }
html.daltonien-achromatopsie .cellule-ko { background: #888 !important; color: #fff !important; }

/* ── Dark mode — menu daltonien ── */
@media (prefers-color-scheme: dark) {
    .daltonien-menu { background: #1e2030; border-color: #2e3260; box-shadow: 0 6px 24px rgba(0,0,0,0.4); }
    .daltonien-option { color: #e2e4f0; border-bottom-color: #2e3260; }
    .daltonien-option:hover { background: #242640; }
    .daltonien-option--active { background: #1e2a5a; color: #7b9af7; }
    .btn-daltonien { background: #1e2a5a; border-color: #2e3260; color: #7b9af7; }
    .btn-daltonien:hover { background: #283276; border-color: #406BDE; }
}
/* ── Dark mode — palettes daltonien ── */
@media (prefers-color-scheme: dark) {

    /* Deutéranopie */
