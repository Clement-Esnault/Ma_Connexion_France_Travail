/* ── Badge alertes nav ── */
.badge-nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--ft-red);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    border-radius: 9px;
    margin-left: 4px;
    vertical-align: middle;
    animation: badgePop 0.3s ease;
}
@keyframes badgePop {
    from { transform: scale(0); }
    to   { transform: scale(1); }
}

/* ── Bouton copier IP ── */
.btn-copier-ip {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    padding: 0 3px;
    opacity: 0.6;
    transition: opacity 0.15s;
    vertical-align: middle;
}
.btn-copier-ip:hover { opacity: 1; }

/* ── Flèches tendance (logs.php) ── */
.tendance          { display: inline-block; font-size: 14px; font-weight: 700; margin-left: 4px; vertical-align: middle; }
.tendance--hausse  { color: #1a7a3c; }
.tendance--baisse  { color: #c0392b; }
.tendance--stable  { color: #6b7a9e; font-size: 12px; }

/* ── Lien voir logs (alertes.php) ── */
.btn-voir-logs {
    display: inline-block;
    background: var(--ft-light);
    color: var(--ft-blue);
    border: 1px solid var(--ft-border);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
}
.btn-voir-logs:hover { background: var(--ft-blue); color: #fff; }

/* ── Dark mode ── */
@media (prefers-color-scheme: dark) {
    .badge-nav          { background: #e57373; }
    .tendance--hausse   { color: #4caf82; }
    .tendance--baisse   { color: #e57373; }
    .tendance--stable   { color: #6b7a9e; }
    .btn-voir-logs      { background: #1e2a5a; color: #7b9af7; border-color: #2e3260; }
    .btn-voir-logs:hover { background: #283276; color: #e2e4f0; }

    /* ── Page alertes / sites insuffisants ── */
.page-header          { background: #1a1c30 !important; border-bottom-color: #E1000F; }
.kpi-bar .kpi         { background: #1e2030 !important; border-top-color: #E1000F; }
.kpi .kpi-val         { color: #e57373 !important; }
.kpi .kpi-lbl         { color: #8892b8 !important; }
.filters              { background: transparent; }
.filters select,
.filters input[type="text"] {
    background: #1e2030 !important;
    color: #e2e4f0 !important;
    border-color: #2e3260 !important;
}
.btn-export           { background: #283276 !important; }
.btn-export:hover     { background: #406BDE !important; }
.table-wrap table     { background: #1e2030 !important; }
.table-wrap thead tr  { background: #1a1c30 !important; }
.table-wrap tbody tr  { border-bottom-color: #2e3260 !important; }
.table-wrap tbody tr:hover { background: #242640 !important; }
.table-wrap td        { color: #e2e4f0 !important; background: transparent !important; }
.site-link            { color: #7b9af7 !important; }
.tag-insuffisant      { background: #c0392b !important; }
.state-msg            { color: #8892b8 !important; }
.alert                { background: #2a2000 !important; border-left-color: #E69F00 !important; color: #e0b030 !important; }
.alert-link           { color: #e0b030 !important; }
.badge-count          { background: #c0392b !important; }
}

